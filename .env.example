# GEMINI_API_KEY: Required for Gemini AI API calls (server-side only via Vercel API routes).
# Set this in Vercel → Project Settings → Environment Variables
# Get a key from https://aistudio.google.com
# IMPORTANT: This key must NOT be prefixed with VITE_ — it must stay server-side only.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# FIREBASE_WEB_API_KEY: Firebase Web API key used server-side to verify Firebase Auth tokens.
# This is the same 'apiKey' value from your firebase-applet-config.json.
# Set this in Vercel → Project Settings → Environment Variables (no VITE_ prefix).
FIREBASE_WEB_API_KEY="MY_FIREBASE_WEB_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# VITE_FCM_VAPID_KEY: Firebase Cloud Messaging VAPID key for push notifications.
# Get this from Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
# IMPORTANT: Rotate this key if it was previously hardcoded in source code.
VITE_FCM_VAPID_KEY="MY_FCM_VAPID_KEY"

# VITE_ADMIN_EMAIL: Email address of the admin user for client-side admin UI gating.
# This is NOT a secret — it's bundled into the client build. The real authorization
# happens in firestore.rules via the isAdmin() function.
VITE_ADMIN_EMAIL="admin@example.com"
