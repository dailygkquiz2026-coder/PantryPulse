rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function isRequestOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.uid;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "dailygkquiz2026@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidGroceryItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.category is string &&
             data.quantity is number &&
             data.unit is string &&
             data.usageFrequency is number &&
             data.uid == request.auth.uid;
    }

    function isValidShoppingItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.status in ['to-buy', 'bought'] &&
             data.uid == request.auth.uid;
    }

    function isValidHousehold(data) {
      return data.members is number && data.members > 0 &&
             data.preferences is list &&
             data.uid == request.auth.uid;
    }

    function isValidSavedRecipe(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string &&
             data.source is string &&
             data.imageUrl is string &&
             (!('link' in data) || data.link is string) &&
             data.ingredients is list &&
             data.instructions is list &&
             data.uid == request.auth.uid;
    }

    function isValidCalorieLog(data) {
      return data.uid == request.auth.uid &&
             data.date is string &&
             data.mealType in ['breakfast', 'lunch', 'dinner', 'snack'] &&
             data.items is list &&
             data.totalCalories is number;
    }

    function isValidUserProfile(data) {
      return data.uid == request.auth.uid &&
             (!('weight' in data) || data.weight is number) &&
             (!('height' in data) || data.height is number) &&
             (!('age' in data) || data.age is number) &&
             (!('gender' in data) || data.gender in ['male', 'female', 'other']) &&
             (!('ethnicity' in data) || data.ethnicity is string) &&
             (!('bmr' in data) || data.bmr is number) &&
             (!('tdee' in data) || data.tdee is number) &&
             (!('shareAnonymousData' in data) || data.shareAnonymousData is bool);
    }

    function isValidFeedback(data) {
      return data.uid == request.auth.uid &&
             data.message is string && data.message.size() > 0 && data.message.size() < 2000;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /inventory/{itemId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidGroceryItem(request.resource.data);
      allow update: if isDocOwner() && isValidGroceryItem(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /calorieLogs/{logId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidCalorieLog(request.resource.data);
      allow update: if isDocOwner() && isValidCalorieLog(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /userProfiles/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /feedback/{feedbackId} {
      allow create: if isAuthenticated() && isValidFeedback(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    match /shoppingList/{itemId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidShoppingItem(request.resource.data);
      allow update: if isDocOwner() && isValidShoppingItem(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /households/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidHousehold(request.resource.data);
      allow update: if isOwner(userId) && isValidHousehold(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /savedRecipes/{recipeId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSavedRecipe(request.resource.data);
      allow update: if isDocOwner() && isValidSavedRecipe(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /fcmTokens/{token} {
      allow read: if isDocOwner();
      allow create, update: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow delete: if isDocOwner();
    }

    match /deletedItems/{itemId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow delete: if isDocOwner();
    }

    match /scanFailures/{failureId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /userActivityLogs/{logId} {
      allow read: if isAdmin();
      allow create, update: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    match /aiUsageLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }
  }
}
