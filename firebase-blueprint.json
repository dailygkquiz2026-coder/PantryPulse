{
  "entities": {
    "GroceryItem": {
      "title": "Grocery Item",
      "description": "An item in the user's pantry inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "purchaseDate": { "type": "string", "format": "date-time" },
        "usageFrequency": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "uid": { "type": "string", "description": "Owner's user ID" }
      },
      "required": ["id", "name", "quantity", "unit", "purchaseDate", "usageFrequency", "uid"]
    },
    "ShoppingListItem": {
      "title": "Shopping List Item",
      "description": "An item the user needs to buy",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "status": { "type": "string", "enum": ["to-buy", "bought"] },
        "uid": { "type": "string" }
      },
      "required": ["id", "name", "quantity", "unit", "status", "uid"]
    },
    "HouseholdInfo": {
      "title": "Household Info",
      "description": "Settings for the user's household",
      "type": "object",
      "properties": {
        "members": { "type": "number" },
        "preferences": { "type": "array", "items": { "type": "string" } },
        "uid": { "type": "string" }
      },
      "required": ["members", "uid"]
    },
    "ScanFailure": {
      "title": "Scan Failure",
      "description": "Log of a failed invoice scan for debugging",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "error": { "type": "string" },
        "mimeType": { "type": "string" },
        "uid": { "type": "string" },
        "userEmail": { "type": "string" }
      },
      "required": ["id", "timestamp", "error", "uid"]
    },
    "SavedRecipe": {
      "title": "Saved Recipe",
      "description": "A recipe saved by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "source": { "type": "string" },
        "imageUrl": { "type": "string" },
        "link": { "type": "string" },
        "ingredients": { "type": "array" },
        "uid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "source", "imageUrl", "ingredients", "uid", "createdAt"]
    },
    "FCMToken": {
      "title": "FCM Token",
      "description": "A push notification token for a user device",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "platform": { "type": "string" }
      },
      "required": ["uid", "updatedAt", "platform"]
    },
    "DeletedItem": {
      "title": "Deleted Item",
      "description": "An item recently deleted from inventory",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "purchaseDate": { "type": "string", "format": "date-time" },
        "deletedAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["name", "category", "quantity", "unit", "purchaseDate", "deletedAt", "uid"]
    },
    "CalorieLog": {
      "title": "Calorie Log",
      "description": "A log of food consumed and its calorie count",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "mealType": { "type": "string", "enum": ["breakfast", "lunch", "dinner", "snack"] },
        "items": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "calories": { "type": "number" },
              "portion": { "type": "string" }
            }
          }
        },
        "totalCalories": { "type": "number" },
        "photoUrl": { "type": "string" }
      },
      "required": ["uid", "date", "mealType", "items", "totalCalories"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Personal health and physical data for calorie tracking",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "weight": { "type": "number", "description": "Weight in kg" },
        "height": { "type": "number", "description": "Height in cm" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "ethnicity": { "type": "string" },
        "age": { "type": "number" },
        "shareAnonymousData": { "type": "boolean" },
        "bmr": { "type": "number" },
        "tdee": { "type": "number" }
      },
      "required": ["uid"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback about the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "appVersion": { "type": "string" }
      },
      "required": ["uid", "message", "timestamp"]
    }
  },
  "firestore": {
    "/inventory/{itemId}": {
      "schema": "GroceryItem",
      "description": "User's pantry items"
    },
    "/shoppingList/{itemId}": {
      "schema": "ShoppingListItem",
      "description": "User's shopping list"
    },
    "/households/{userId}": {
      "schema": "HouseholdInfo",
      "description": "User's household settings"
    },
    "/userProfiles/{userId}": {
      "schema": "UserProfile",
      "description": "User's health and physical profile"
    },
    "/calorieLogs/{logId}": {
      "schema": "CalorieLog",
      "description": "User's daily food and calorie logs"
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback submissions"
    },
    "/scanFailures/{failureId}": {
      "schema": "ScanFailure",
      "description": "Logs of failed scans for developers"
    },
    "/savedRecipes/{recipeId}": {
      "schema": "SavedRecipe",
      "description": "Recipes saved by the user"
    },
    "/fcmTokens/{token}": {
      "schema": "FCMToken",
      "description": "User push notification tokens"
    },
    "/deletedItems/{itemId}": {
      "schema": "DeletedItem",
      "description": "Recently deleted inventory items"
    }
  }
}
